# data.gov.in API key (register at https://data.gov.in)
DATA_GOV_IN_API_KEY=

# LTA DataMall AccountKey (free — https://datamall.lta.gov.sg)
# Without this, pipeline uses tests/fixtures/lta_bus_arrival_sample.json
LTA_DATAMALL_ACCOUNT_KEY=

# Optional: comma-separated 5-digit bus stop codes for MVP ingest
# LTA_BUS_STOP_CODES=83139,01012,44009

# Guardrails: max bus stops per run (default 5); one API call per stop (~2–4 KB each)
# LTA_MAX_STOPS_PER_RUN=5

# Override guardrail for larger ingests (or use CLI --allow-large)
# LTA_ALLOW_LARGE_INGEST=1

# Force fixture ingest even when API key is set (CI)
# LTA_USE_FIXTURE=1
